{
  "id": "xr-house-demo",
  "name": "NexusRealtime XR House Demo",
  "target": "webxr-adaptive-host",
  "entrySequence": "scene.sequence.json",
  "kits": [
    "xr-session-kit",
    "xr-frame-kit",
    "xr-layer-kit",
    "xr-render-descriptor-kit",
    "xr-input-kit",
    "xr-grab-throw-kit",
    "simple-rigid-body-kit",
    "toon-visual-kit",
    "sky-gradient-kit"
  ],
  "webxr": {
    "mode": "immersive-vr",
    "requiredFeatures": ["local-floor"],
    "optionalFeatures": ["hand-tracking", "anchors", "haptics"]
  },
  "hostProfiles": [
    {
      "id": "android-canvas",
      "mode": "android-canvas",
      "stereo": false,
      "swapchain": "not-required",
      "input": "pointer-only"
    },
    {
      "id": "stereo-panel",
      "mode": "stereo-panel",
      "stereo": true,
      "swapchain": "optional-stereo-layer",
      "input": "synthetic-stereo-hands"
    },
    {
      "id": "quest-openxr",
      "mode": "quest-openxr",
      "stereo": true,
      "swapchain": "required-open-xr-projection",
      "input": "open-xr-actions",
      "backend": "vulkan"
    }
  ],
  "renderer": {
    "mode": "descriptor-consumer",
    "preferredBackend": "vulkan",
    "fallbackBackend": "gles",
    "stereo": true,
    "toonBands": 4,
    "outline": "sigmoid-depth-normal",
    "sky": "gradient-horizon"
  }
}
